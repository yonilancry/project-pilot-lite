<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ProjectPilotLite.Client.Shared.ViewModels"
             xmlns:views="using:ProjectPilotLite.Avalonia.Views"
             x:Class="ProjectPilotLite.Avalonia.App"
             RequestedThemeVariant="Default">

    <Application.DataTemplates>
        <DataTemplate DataType="vm:DashboardViewModel">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="vm:ProjectListViewModel">
            <views:ProjectListView />
        </DataTemplate>
        <DataTemplate DataType="vm:ProjectDetailViewModel">
            <views:ProjectDetailView />
        </DataTemplate>
        <DataTemplate DataType="vm:ProjectCreateViewModel">
            <views:ProjectCreateView />
        </DataTemplate>
        <DataTemplate DataType="vm:TaskCreateViewModel">
            <views:TaskCreateView />
        </DataTemplate>
        <DataTemplate DataType="vm:DeliverableCreateViewModel">
            <views:DeliverableCreateView />
        </DataTemplate>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>
