<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ProjectPilotLite.Client.Shared.ViewModels"
             x:Class="ProjectPilotLite.Avalonia.Views.TaskCreateView"
             x:DataType="vm:TaskCreateViewModel">

    <StackPanel Spacing="8" MaxWidth="520" HorizontalAlignment="Left">
        <TextBlock Text="Nouvelle tâche" FontSize="22" FontWeight="SemiBold" />

        <TextBlock Text="Titre *" />
        <TextBox Text="{Binding Title}" />

        <TextBlock Text="Description" />
        <TextBox Text="{Binding Description}" AcceptsReturn="True" Height="80" TextWrapping="Wrap" />

        <TextBlock Text="Priorité" />
        <ComboBox ItemsSource="{Binding PriorityOptions}" SelectedItem="{Binding SelectedPriority}" HorizontalAlignment="Stretch">
            <ComboBox.ItemTemplate>
                <DataTemplate x:CompileBindings="False">
                    <TextBlock Text="{Binding Label}" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Text="Statut" />
        <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding SelectedStatus}" HorizontalAlignment="Stretch">
            <ComboBox.ItemTemplate>
                <DataTemplate x:CompileBindings="False">
                    <TextBlock Text="{Binding Label}" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626" IsVisible="{Binding HasError}" TextWrapping="Wrap" />

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <Button Content="Enregistrer" Command="{Binding SaveCommand}" />
            <Button Content="Annuler" Command="{Binding CancelCommand}" />
        </StackPanel>
    </StackPanel>
</UserControl>
