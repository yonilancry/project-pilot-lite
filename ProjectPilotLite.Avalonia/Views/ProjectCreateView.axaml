<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ProjectPilotLite.Client.Shared.ViewModels"
             x:Class="ProjectPilotLite.Avalonia.Views.ProjectCreateView"
             x:DataType="vm:ProjectCreateViewModel">

    <StackPanel Spacing="8" MaxWidth="520" HorizontalAlignment="Left">
        <TextBlock Text="Nouveau projet" FontSize="22" FontWeight="SemiBold" />

        <TextBlock Text="Nom *" />
        <TextBox Text="{Binding Name}" />

        <TextBlock Text="Responsable *" />
        <TextBox Text="{Binding Owner}" />

        <TextBlock Text="Description" />
        <TextBox Text="{Binding Description}" AcceptsReturn="True" Height="80" TextWrapping="Wrap" />

        <TextBlock Text="Date de début" />
        <DatePicker SelectedDate="{Binding StartDate}" />

        <TextBlock Text="Date limite" />
        <DatePicker SelectedDate="{Binding Deadline}" />

        <TextBlock Text="Statut" />
        <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding SelectedStatus}" HorizontalAlignment="Stretch">
            <ComboBox.ItemTemplate>
                <DataTemplate x:CompileBindings="False">
                    <TextBlock Text="{Binding Label}" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626" IsVisible="{Binding HasError}" TextWrapping="Wrap" />

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <Button Content="Enregistrer" Command="{Binding SaveCommand}" />
            <Button Content="Annuler" Command="{Binding CancelCommand}" />
        </StackPanel>
    </StackPanel>
</UserControl>
