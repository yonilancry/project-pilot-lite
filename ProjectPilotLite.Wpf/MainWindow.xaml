<Window x:Class="ProjectPilotLite.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ProjectPilotLite.Client.Shared.ViewModels;assembly=ProjectPilotLite.Client.Shared"
        Title="ProjectPilot Lite" Height="660" Width="980" MinHeight="520" MinWidth="820">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1F2937" Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="ProjectPilot Lite" Foreground="White" FontSize="18"
                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,16,0" />
                <Button Content="Projets" Command="{Binding ShowProjectsCommand}" Padding="10,4" Margin="0,0,8,0" />
                <Button Content="Tableau de bord" Command="{Binding ShowDashboardCommand}" Padding="10,4" />
            </StackPanel>
        </Border>

        <ContentControl Content="{Binding Current}" Margin="16" />
    </DockPanel>
</Window>
