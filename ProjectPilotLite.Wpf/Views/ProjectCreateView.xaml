<UserControl x:Class="ProjectPilotLite.Wpf.Views.ProjectCreateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel MaxWidth="520" HorizontalAlignment="Left">
        <TextBlock Text="Nouveau projet" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,8" />

        <TextBlock Text="Nom *" />
        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

        <TextBlock Text="Responsable *" />
        <TextBox Text="{Binding Owner, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

        <TextBlock Text="Description" />
        <TextBox Text="{Binding Description}" AcceptsReturn="True" Height="80" TextWrapping="Wrap" Margin="0,0,0,8" />

        <TextBlock Text="Date de début" />
        <DatePicker SelectedDate="{Binding StartDate, Converter={StaticResource DateConverter}}" Margin="0,0,0,8" />

        <TextBlock Text="Date limite" />
        <DatePicker SelectedDate="{Binding Deadline, Converter={StaticResource DateConverter}}" Margin="0,0,0,8" />

        <TextBlock Text="Statut" />
        <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding SelectedStatus}" DisplayMemberPath="Label" Margin="0,0,0,8" />

        <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626" TextWrapping="Wrap"
                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}" />

        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="Enregistrer" Command="{Binding SaveCommand}" Padding="12,5" Margin="0,0,8,0" />
            <Button Content="Annuler" Command="{Binding CancelCommand}" Padding="12,5" />
        </StackPanel>
    </StackPanel>
</UserControl>
