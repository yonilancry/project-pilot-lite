<UserControl x:Class="ProjectPilotLite.Wpf.Views.TaskCreateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel MaxWidth="520" HorizontalAlignment="Left">
        <TextBlock Text="Nouvelle tâche" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,8" />

        <TextBlock Text="Titre *" />
        <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

        <TextBlock Text="Description" />
        <TextBox Text="{Binding Description}" AcceptsReturn="True" Height="80" TextWrapping="Wrap" Margin="0,0,0,8" />

        <TextBlock Text="Priorité" />
        <ComboBox ItemsSource="{Binding PriorityOptions}" SelectedItem="{Binding SelectedPriority}" DisplayMemberPath="Label" Margin="0,0,0,8" />

        <TextBlock Text="Statut" />
        <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding SelectedStatus}" DisplayMemberPath="Label" Margin="0,0,0,8" />

        <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626" TextWrapping="Wrap"
                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}" />

        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="Enregistrer" Command="{Binding SaveCommand}" Padding="12,5" Margin="0,0,8,0" />
            <Button Content="Annuler" Command="{Binding CancelCommand}" Padding="12,5" />
        </StackPanel>
    </StackPanel>
</UserControl>
