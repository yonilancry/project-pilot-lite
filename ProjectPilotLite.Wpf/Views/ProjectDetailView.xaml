<UserControl x:Class="ProjectPilotLite.Wpf.Views.ProjectDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel>
            <Button Content="← Retour aux projets" Command="{Binding BackCommand}" HorizontalAlignment="Left" Padding="10,4" />

            <TextBlock Text="{Binding ProjectName}" FontSize="24" FontWeight="Bold" Margin="0,8,0,0" />
            <TextBlock Text="{Binding Owner}" Foreground="#4B5563" />
            <TextBlock Text="{Binding DatesText}" Foreground="#4B5563" />
            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="0,4,0,0" />

            <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626" TextWrapping="Wrap" Margin="0,4,0,0"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}" />

            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <TextBlock Text="Statut du projet :" VerticalAlignment="Center" Margin="0,0,8,0" />
                <ComboBox ItemsSource="{Binding ProjectStatusOptions}" SelectedItem="{Binding SelectedProjectStatus}"
                          DisplayMemberPath="Label" MinWidth="160" Margin="0,0,8,0" />
                <Button Content="Changer le statut" Command="{Binding ChangeProjectStatusCommand}" Padding="10,4" />
            </StackPanel>

            <TextBlock Text="Tâches" FontSize="18" FontWeight="SemiBold" Margin="0,14,0,6" />
            <Button Content="Ajouter une tâche" Command="{Binding AddTaskCommand}" HorizontalAlignment="Left" Padding="10,4" Margin="0,0,0,6" />
            <ListView ItemsSource="{Binding Tasks}" SelectedItem="{Binding SelectedTask}" Height="160">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Titre" DisplayMemberBinding="{Binding Title}" Width="330" />
                        <GridViewColumn Header="Priorité" DisplayMemberBinding="{Binding PriorityLabel}" Width="120" />
                        <GridViewColumn Header="Statut" DisplayMemberBinding="{Binding StatusLabel}" Width="120" />
                    </GridView>
                </ListView.View>
            </ListView>
            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                <TextBlock Text="Nouveau statut :" VerticalAlignment="Center" Margin="0,0,8,0" />
                <ComboBox ItemsSource="{Binding TaskStatusOptions}" SelectedItem="{Binding SelectedTaskStatus}"
                          DisplayMemberPath="Label" MinWidth="140" Margin="0,0,8,0" />
                <Button Content="Changer le statut" Command="{Binding ChangeTaskStatusCommand}" Padding="10,4" />
            </StackPanel>

            <TextBlock Text="Livrables" FontSize="18" FontWeight="SemiBold" Margin="0,14,0,6" />
            <Button Content="Ajouter un livrable" Command="{Binding AddDeliverableCommand}" HorizontalAlignment="Left" Padding="10,4" Margin="0,0,0,6" />
            <ListView ItemsSource="{Binding Deliverables}" SelectedItem="{Binding SelectedDeliverable}" Height="160">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Nom" DisplayMemberBinding="{Binding Name}" Width="200" />
                        <GridViewColumn Header="Type" DisplayMemberBinding="{Binding TypeLabel}" Width="120" />
                        <GridViewColumn Header="Statut" DisplayMemberBinding="{Binding StatusLabel}" Width="100" />
                        <GridViewColumn Header="Référence" DisplayMemberBinding="{Binding PathOrUrl}" Width="260" />
                    </GridView>
                </ListView.View>
            </ListView>
            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                <Button Content="Valider" Command="{Binding ApproveDeliverableCommand}" Padding="10,4" Margin="0,0,8,0" />
                <Button Content="Refuser" Command="{Binding RejectDeliverableCommand}" Padding="10,4" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
